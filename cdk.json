{
  "app": "npx ts-node --prefer-ts-exts bin/app.ts",
  "watch": {
    "include": ["**"],
    "exclude": [
      "README.md",
      "cdk*.json",
      "**/*.d.ts",
      "**/*.js",
      "tsconfig.json",
      "package*.json",
      "yarn.lock",
      "node_modules"
    ]
  },
  "context": {
    "@aws-cdk/aws-lambda:recognizeLayerVersion": true,
    "@aws-cdk/core:checkSecretUsage": true,
    "@aws-cdk-lib/aws-lambda:recognizeVersionProps": true,
    "@aws-cdk/core:target-partitions": ["aws"],
    "@aws-cdk-lib/aws-ecs:removeDefaultDeploymentAlarm": true,

    "region": "ap-northeast-2",
    "modelPrefix": "",
    "litellmImageTag": "main-v1.83.14-stable",
    "certificateArn": "",
    "allowedCidrs": "",
    "oktaIssuer": "",
    "oktaClientId": "",
    "oktaClientSecret": ""
  }
}
